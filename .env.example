# OPENAI_API_KEY
# Gérée directement sur Vercel - ne pas ajouter ici en production.
# Pour tester le mode API en local, créer un fichier .env.local
# (non commité) et y ajouter : OPENAI_API_KEY=sk-...
# --------------------------------------------------------------

# Email destinataire pour les brouillons (visible côté client)
NEXT_PUBLIC_CONTACT_EMAIL=communication@bussigny.ch

# Lien du formulaire ClickUp pré-rempli (visible côté client)
NEXT_PUBLIC_FORM_URL=https://forms.clickup.com/...
